  <script>
    function toggleMobileNav(){var n=document.getElementById('mobileNav'),h=document.querySelector('.nav-hamburger'),open=n.classList.toggle('active');h.classList.toggle('active');h.setAttribute('aria-expanded',open);}
    function closeMobileNav(){var n=document.getElementById('mobileNav'),h=document.querySelector('.nav-hamburger');n.classList.remove('active');h.classList.remove('active');h.setAttribute('aria-expanded','false');}
    document.querySelector('.nav-hamburger').addEventListener('click',toggleMobileNav);
    document.querySelectorAll('.nav-dropdown-toggle').forEach(function(t){t.addEventListener('click',function(){var m=this.nextElementSibling,e=this.getAttribute('aria-expanded')==='true';this.setAttribute('aria-expanded',!e);if(m)m.style.display=e?'none':'block';});});
    document.addEventListener('click',function(e){if(!e.target.closest('.nav-dropdown')){document.querySelectorAll('.nav-dropdown-menu').forEach(function(m){m.style.display='none';});document.querySelectorAll('.nav-dropdown-toggle').forEach(function(t){t.setAttribute('aria-expanded','false');});}});
    document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeMobileNav();document.querySelectorAll('.nav-dropdown-menu').forEach(function(m){m.style.display='none';});document.querySelectorAll('.nav-dropdown-toggle').forEach(function(t){t.setAttribute('aria-expanded','false');});}});
  </script>
  <script>
    /* ── Stripe Checkout (Sprint 5C) ── */
    function initCheckout(planId) {
      var btn = event && event.target;
      if (btn) { btn.disabled = true; btn.textContent = 'Processing\u2026'; }
      fetch('/.netlify/functions/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ planId: planId })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Checkout error: ' + (data.error || 'Unknown error'));
          if (btn) { btn.disabled = false; btn.textContent = 'Purchase & Download'; }
        }
      })
      .catch(function(err) {
        alert('Connection error. Please try again.');
        if (btn) { btn.disabled = false; btn.textContent = 'Purchase & Download'; }
      });
    }
  </script>
